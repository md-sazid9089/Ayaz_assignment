# Environment variables for Product Price Tracking System
# Copy this file to .env.local and update with your values

# API Configuration (optional for frontend-only)
VITE_API_BASE_URL=http://localhost:3000

# Analytics (optional)
VITE_ANALYTICS_ID=

# Feature Flags
VITE_ENABLE_PRICE_ALERTS=true
VITE_ENABLE_EXPORT=true

# Deployment
VITE_APP_ENV=development
