# Database Configuration
# Get your MySQL connection string from PlanetScale, AWS RDS, or Aiven
DATABASE_URL="mysql://user:password@host:3306/database_name"

# Authentication
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key"

# External APIs
# Get your keys from https://firecrawl.dev and https://resend.com
FIRECRAWL_API_KEY="fc-xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# Admin Access
# Key for protected maintenance endpoints
ADMIN_API_KEY="your-admin-api-key"

# Email Configuration
FROM_EMAIL="noreply@yourdomain.com"

# Environment
NODE_ENV="production"
