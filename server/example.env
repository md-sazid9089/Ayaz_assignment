// example.env
// This file shows all available environment variables with examples
// Copy this to .env.local and fill in your actual values

# ============================================
# REQUIRED: Database Configuration
# ============================================
# Format: mysql://username:password@host:port/database
# For local MySQL:
DATABASE_URL="mysql://root:password@localhost:3306/price_tracker_db"

# ============================================
# REQUIRED: Security Keys
# ============================================
# Generate JWT secret with: openssl rand -base64 32
JWT_SECRET="your-generated-jwt-secret-key-here"

# Generate Admin API key with: openssl rand -base64 32
ADMIN_API_KEY="your-generated-admin-api-key-here"

# ============================================
# REQUIRED: External API Keys
# ============================================
# Get from: https://www.firecrawl.dev/dashboard
FIRECRAWL_API_KEY="your-firecrawl-api-key-here"

# Get from: https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key-here"

# ============================================
# REQUIRED: Email Configuration
# ============================================
# Must be verified in Resend dashboard
FROM_EMAIL="noreply@pricetracksystem.com"

# ============================================
# REQUIRED: Environment
# ============================================
NODE_ENV="development"

# ============================================
# OPTIONAL: Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ============================================
# OPTIONAL: Logging
# ============================================
LOG_LEVEL="info"

# ============================================
# OPTIONAL: Monitoring (Sentry for error tracking)
# ============================================
# SENTRY_DSN="https://key@sentry.io/project-id"

# ============================================
# OPTIONAL: Third-party Services
# ============================================
# For future integrations
# STRIPE_SECRET_KEY="your-stripe-key"
# STRIPE_PUBLIC_KEY="your-stripe-public-key"
